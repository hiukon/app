{
  "expo": {
    "name": "HaNoiBrain",
    "slug": "hanobrain",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.hanobrain.app",
      "icon": "./src/assets/images/T.png",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow HaNoiBrain to recognize your speech",
        "NSMicrophoneUsageDescription": "Allow HaNoiBrain to access your microphone for voice input",
        "NSPhotoLibraryUsageDescription": "Allow HaNoiBrain to access your photos for file upload",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./src/assets/images/T.png",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.hanobrain.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.DETECT_SCREEN_CAPTURE"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {},
    "extra": {
      "API_URL": "https://api.hanobrain.vn",
      "eas": {
        "projectId": "2eabab93-b214-4735-8485-6bf9071ecdb2"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          },
          "ios": {
            "deploymentTarget": "13.4"
          }
        }
      ]
    ]
  }
}